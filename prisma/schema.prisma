generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  user_id  String @id @default(uuid()) @db.VarChar(36)
  username String @db.VarChar(55)
  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255) 
  country  String @db.VarChar(55)
  role     String @db.VarChar(25)

  // Relasi: Satu User bisa memiliki banyak rekor Speedrun
  runs     Run[]

  @@map("users")
}

model Game {
  game_id      String @id @default(uuid()) @db.VarChar(36)
  title        String @db.VarChar(100)
  genre        String @db.VarChar(55)
  release_year Int

  // Relasi: Satu Game bisa memiliki banyak rekor Speedrun
  runs         Run[]

  @@map("games")
}

model Run {
  run_id          String @id @default(uuid()) @db.VarChar(36)
  time_in_seconds Int    
  video_url       String @db.VarChar(255) // Link bukti video YouTube/dll
  
  // Foreign Keys
  user_id         String @db.VarChar(36)
  game_id         String @db.VarChar(36)

  // Definisi Relasi
  user            User   @relation(fields: [user_id], references: [user_id])
  game            Game   @relation(fields: [game_id], references: [game_id])

  @@map("runs")
}